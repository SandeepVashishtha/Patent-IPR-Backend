PORT=5000
NODE_ENV=development
JWT_SECRET=replace_with_a_very_strong_secret

# Option 1: Use full connection string
# DATABASE_URL=postgresql://postgres:password@localhost:5432/express_backend

# Option 2: Use PG variables (Neon-friendly)
PGHOST=localhost
PGPORT=5432
PGDATABASE=express_backend
PGUSER=postgres
PGPASSWORD=password
PGSSLMODE=disable
PGCHANNELBINDING=disable
